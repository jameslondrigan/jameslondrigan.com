---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const hasPosts = posts.length > 0;
---

<Base title="Writing">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <div class="mb-12">
      <p class="text-xs font-mono text-muted uppercase tracking-widest mb-4">Writing</p>
      <h1 class="text-4xl leading-tight">{hasPosts ? 'Writing' : 'Coming soon.'}</h1>
    </div>

    {hasPosts ? (
      <ul class="space-y-0">
        {posts.map(post => (
          <li class="border-b border-ink/10 py-8 first:pt-0">
            <a href={`/writing/${post.slug}`} class="group block">
              <p class="text-xs font-mono text-muted mb-2">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h2 class="text-xl mb-2 group-hover:text-maroon transition-colors">{post.data.title}</h2>
              <p class="text-muted leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-lg text-muted leading-relaxed max-w-lg">
        Notes on building systems, lessons from projects, and whatever else earns a few hundred
        words. Check back soon.
      </p>
    )}
  </div>
</Base>
