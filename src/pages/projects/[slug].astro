---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const d = project.data;

const displayTags = d.stack ?? d.tags ?? [];
const githubUrl = d.repoUrl ?? d.repo;
const metaDescription = d.description ?? d.subtitle ?? d.title;
const hasMeta = d.course || d.semester || d.team || d.role;
---

<Base title={d.title} description={metaDescription}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-16 pb-8 border-b border-ink/10">
      <a
        href="/projects"
        class="text-xs font-mono text-muted uppercase tracking-widest hover:text-maroon transition-colors"
      >
        ← Projects
      </a>

      <h1 class="text-4xl leading-tight mt-6 mb-2">{d.title}</h1>

      {d.subtitle && (
        <p class="text-lg text-muted leading-relaxed italic mb-6">{d.subtitle}</p>
      )}
      {!d.subtitle && d.description && (
        <p class="text-lg text-muted leading-relaxed mb-6">{d.description}</p>
      )}

      {hasMeta && (
        <dl class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-2 text-sm mb-6 max-w-xl">
          {d.course && (
            <>
              <dt class="font-mono text-xs text-muted uppercase tracking-widest self-start pt-0.5">Course</dt>
              <dd>{d.course}</dd>
            </>
          )}
          {d.semester && (
            <>
              <dt class="font-mono text-xs text-muted uppercase tracking-widest self-start pt-0.5">Semester</dt>
              <dd>{d.semester}</dd>
            </>
          )}
          {d.team && (
            <>
              <dt class="font-mono text-xs text-muted uppercase tracking-widest self-start pt-0.5">Team</dt>
              <dd>{d.team}</dd>
            </>
          )}
          {d.role && (
            <>
              <dt class="font-mono text-xs text-muted uppercase tracking-widest self-start pt-0.5">My role</dt>
              <dd>{d.role}</dd>
            </>
          )}
        </dl>
      )}

      {displayTags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mb-6">
          {displayTags.map(tag => (
            <li class="text-xs font-mono px-2 py-1 bg-paper text-muted">{tag}</li>
          ))}
        </ul>
      )}

      {(d.liveUrl || githubUrl) && (
        <div class="flex gap-5 text-sm">
          {d.liveUrl && (
            <a
              href={d.liveUrl}
              class="text-maroon hover:underline underline-offset-2"
              target="_blank"
              rel="noopener noreferrer"
            >
              Live site ↗
            </a>
          )}
          {githubUrl && (
            <a
              href={githubUrl}
              class="text-maroon hover:underline underline-offset-2"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub ↗
            </a>
          )}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<script>
  import mermaid from 'mermaid';

  mermaid.initialize({
    startOnLoad: false,
    theme: 'neutral',
    themeVariables: {
      background: '#F2EDE3',
      mainBkg: '#F2EDE3',
      nodeBorder: '#6B6560',
      clusterBkg: '#FAF7F0',
      titleColor: '#1A1715',
      edgeLabelBackground: '#FAF7F0',
      lineColor: '#6B6560',
      primaryColor: '#F2EDE3',
      primaryTextColor: '#1A1715',
      primaryBorderColor: '#6B6560',
    },
    fontFamily: '"JetBrains Mono Variable", ui-monospace, monospace',
  });

  document.addEventListener('DOMContentLoaded', async () => {
    // Shiki wraps in pre[data-language]; plain MDX uses code.language-mermaid
    const pres = Array.from(new Set([
      ...document.querySelectorAll<HTMLPreElement>('pre[data-language="mermaid"]'),
      ...document.querySelectorAll<HTMLPreElement>('pre:has(> code.language-mermaid)'),
    ]));

    for (const pre of pres) {
      const code = pre.querySelector('code');
      const content = code?.textContent?.trim() ?? '';
      if (!content) continue;

      const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
      try {
        const { svg } = await mermaid.render(id, content);
        const wrapper = document.createElement('div');
        wrapper.className = 'mermaid-diagram';
        wrapper.innerHTML = svg;
        pre.replaceWith(wrapper);
      } catch {
        // leave as styled code block if render fails
      }
    }
  });
</script>
