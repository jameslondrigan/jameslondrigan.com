---
interface Props {
  title: string;
  description: string;
  slug: string;
  tags?: string[];
}

const { title, description, slug, tags = [] } = Astro.props;
---

<a href={`/projects/${slug}`} class="group block border border-ink/10 p-6 hover:border-maroon/40 transition-colors">
  <h3 class="text-lg mb-2 leading-snug group-hover:text-maroon transition-colors">{title}</h3>
  <p class="text-sm text-muted leading-relaxed mb-4">{description}</p>
  {tags.length > 0 && (
    <ul class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <li class="text-xs font-mono px-2 py-0.5 bg-paper text-muted">{tag}</li>
      ))}
    </ul>
  )}
</a>
